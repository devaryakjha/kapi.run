{
  "name": "kapi.run",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:landing": "bun run --cwd apps/landing dev",
    "deploy:landing": "bun run --cwd apps/landing deploy",
    "build": "bun run --filter '@kapi/web' build",
    "check": "bun run --cwd apps/web check && bun run --cwd apps/web typecheck && bun run --cwd apps/api typecheck",
    "lint": "bun run --filter '@kapi/web' lint",
    "test": "bun run --filter '@kapi/web' test"
  },
  "overrides": {
    "fast-uri": "^4.0.0",
    "hono": "^4.12.26",
    "shell-quote": "^1.8.4",
    "undici": "^8.5.0",
    "vite": "8.0.16",
    "ws": "^8.21.0"
  }
}
