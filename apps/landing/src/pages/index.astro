---
import "../styles/global.css";

const githubUrl = "https://github.com/devaryakjha/kapi.run";

const items = [
  {
    name: "Smash burger",
    person: "Arya",
    note: "double patty",
    price: "₹438",
    image:
      "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?auto=format&fit=crop&w=160&q=90",
  },
  {
    name: "Paneer makhani bowl",
    person: "Anjali",
    note: "no onions",
    price: "₹319",
    image:
      "https://images.unsplash.com/photo-1631452180539-96aca7d48617?auto=format&fit=crop&w=160&q=90",
  },
  {
    name: "Masala fries",
    person: "VM",
    note: "extra spicy",
    price: "₹189",
    image:
      "https://images.unsplash.com/photo-1630384060421-cb20d0e0649d?auto=format&fit=crop&w=160&q=90",
  },
];

const steps = ["Create a run", "Share the link", "Sync the cart"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="kapi.run — shared Swiggy lunch runs without the back-and-forth."
    />
    <meta property="og:title" content="kapi.run" />
    <meta
      property="og:description"
      content="Shared lunch runs without the back-and-forth."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kapi.run" />
    <link rel="icon" href="/kapi-mark.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <title>kapi.run</title>
  </head>
  <body>
    <div class="page">
      <nav class="nav" aria-label="Primary">
        <a class="brand" href="/" aria-label="kapi.run home">
          <img class="brand-mark" src="/kapi-mark.svg" alt="" />
          <span>kapi.run</span>
        </a>
        <a class="btn" href={githubUrl} rel="noreferrer">
          <svg aria-hidden="true" viewBox="0 0 16 16">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.67 7.67 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            ></path>
          </svg>
          GitHub
        </a>
      </nav>

      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <h1 id="hero-title">
            Shared lunch runs,<br />sorted.
          </h1>
          <p class="lede">
            Everyone picks their own items. One Swiggy cart, zero back-and-forth.
          </p>
          <a class="btn-primary" href={githubUrl} rel="noreferrer">
            <svg aria-hidden="true" viewBox="0 0 16 16">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.67 7.67 0 0 1 8 3.86c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
              ></path>
            </svg>
            Star on GitHub
          </a>
          <p class="powered">
            <img src="/swiggy.svg" alt="" />
            Powered by Swiggy MCP
          </p>
        </div>

        <div class="card-wrap">
          <article class="order-card" aria-label="Lunch run example">
            <header class="card-head">
              <p class="card-head-title">
                <strong>Lunch run</strong>
                <span class="sep">·</span>
                Truffles, Indiranagar
              </p>
              <div class="timer-pill">
                <span class="timer-dot" aria-hidden="true"></span>
                closes in 08:42
              </div>
            </header>

            <div class="item-list">
              {
                items.map((item) => (
                  <div class="item-row">
                    <img src={item.image} alt="" />
                    <div class="item-info">
                      <p class="item-name">{item.name}</p>
                      <p class="item-meta">
                        {item.person}
                        <span class="sep">·</span>
                        {item.note}
                      </p>
                    </div>
                    <p class="item-price">{item.price}</p>
                  </div>
                ))
              }
            </div>

            <footer class="card-foot">
              <div class="avatars" aria-label="Participants">
                <span aria-label="AJ">AJ</span>
                <span aria-label="NK">NK</span>
                <span aria-label="VM">VM</span>
              </div>
              <div class="total-col">
                <p>9 items · 3 people</p>
                <strong>₹1,482</strong>
              </div>
              <button class="btn-sync" type="button">Sync cart</button>
            </footer>
          </article>
        </div>
      </section>

      <section class="flow" aria-label="How it works">
        {
          steps.map((step, index) => (
            <div class="flow-step">
              <span class="step-num">{String(index + 1).padStart(2, "0")}</span>
              <span class="step-label">{step}</span>
            </div>
          ))
        }
      </section>
    </div>
  </body>
</html>
